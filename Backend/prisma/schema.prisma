generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  CREATOR
  ADMIN
}

enum SocialProvider {
  GOOGLE
  GITHUB
  DISCORD
}

enum CharacterStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

enum CharacterVisibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

enum EntitlementSource {
  PATREON
  STRIPE
  MANUAL
}

enum EntitlementStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

/// Subscription tier catalog (PDF: Tiers.code, message_limit). Used for chat quota and optional User.tierCode.
model Tier {
  code          String @id
  messageLimit  Int
  periodDays    Int    @default(30)
  label         String?
  users         User[]
}

enum ChatMessageRole {
  USER
  ASSISTANT
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  username                String                   @unique
  passwordHash            String?
  role                    UserRole                 @default(USER)
  /// Optional FK to Tier — overrides Patreon-derived tier for message limits when set (PDF: Users.tier_code).
  tierCode                String?
  tier                    Tier?                    @relation(fields: [tierCode], references: [code], onDelete: SetNull, onUpdate: Cascade)
  isEmailVerified         Boolean                  @default(false)
  isBanned                Boolean                  @default(false)
  /// When this admin last opened Official VRMs; used for sidebar “new official” badge (per admin).
  officialVrmsListSeenAt  DateTime?
  /// When this admin last opened Community VRMs; used for sidebar “new community” badge (per admin).
  communityVrmsListSeenAt DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  characters              Character[]
  hearts                  CharacterHeart[]
  reviews                 Review[]
  patreonAccount          PatreonAccount?
  patreonOauthState       PatreonOAuthState[]
  entitlementGrants       Entitlement[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  oauthAccounts           OAuthAccount[]
  sessions                Session[]
  chatMessageUsage        ChatMessageUsage[]
  storyPosts              StoryPost[]
  storyPostLikes          StoryPostLike[]
  characterCardsCreated   CharacterCard[]
  chatSessions            ChatSession[]
}

/// Append-only entries for admin dashboard “System Activity” (bans, etc.).
model SystemActivityLog {
  id        String   @id @default(cuid())
  message   String
  tone      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Character {
  id               String                @id @default(cuid())
  slug             String                @unique
  name             String
  fullName         String?
  tagline          String?
  description      String?
  personality      String?
  scenario         String?
  firstMessage     String?
  exampleDialogs   String?
  vroidFileUrl     String?
  previewImageUrl  String?
  legacyFileHash   String?
  legacyTier       Int?
  legacyHeyWaifu   Int?
  status           CharacterStatus       @default(DRAFT)
  visibility       CharacterVisibility   @default(PRIVATE)
  /// True when the owning account is an admin (admin-uploaded VRMs); mirrored for API compatibility.
  officialListing  Boolean               @default(false)
  isPatreonGated   Boolean               @default(false)
  minimumTierCents Int?
  /// Optional note from admin when status is set to REJECTED (shown in moderation / future creator messaging).
  moderationRejectReason String?
  heartsCount      Int                   @default(0)
  viewsCount       Int                   @default(0)
  ownerId          String
  owner            User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  reviews             Review[]
  hearts              CharacterHeart[]
  chatStartLedgerRows CharacterChatStartLedger[]
  systemScanReports    CharacterSystemScanReport[]
  storyPosts           StoryPost[]
  /// Primary character card (PDF: CharacterCards) — AI persona / chat context. Mirrors legacy fields on Character.
  characterCard        CharacterCard?
  createdAt           DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  publishedAt      DateTime?

  @@index([ownerId, status])
  @@index([status, visibility])
}

/// PDF: CharacterCards — persona / behavior layer on top of base Character (visual avatar).
model CharacterCard {
  id              String    @id @default(cuid())
  characterId     String    @unique
  creatorUserId   String
  fullName        String?
  description     String?
  personality     String?
  scenario        String?
  firstMessage    String?
  exampleDialogs  String?
  isPublic        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  creator         User      @relation(fields: [creatorUserId], references: [id], onDelete: Cascade)
  chatSessions    ChatSession[]

  @@index([creatorUserId])
}

/// PDF: ChatSessions — groups messages per user + character card.
model ChatSession {
  id              String @id @default(cuid())
  userId          String
  characterCardId String
  createdAt       DateTime @default(now())
  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)
  characterCard   CharacterCard @relation(fields: [characterCardId], references: [id], onDelete: Cascade)
  messages        ChatMessage[]

  @@index([userId, createdAt])
  @@index([characterCardId])
}

/// PDF: ChatMessages — chat history (role + content).
model ChatMessage {
  id        String @id @default(cuid())
  sessionId String
  role      ChatMessageRole
  content   String
  createdAt DateTime @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

/// Moderation/system scan output (e.g. Unity-side checks) stored per character (append-only).
model CharacterSystemScanReport {
  id          String   @id @default(cuid())
  characterId String
  overall     String
  issuesCount Int      @default(0)
  summary     String
  reportJson  Json
  createdAt   DateTime @default(now())

  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, createdAt])
}

model CharacterHeart {
  id          String    @id @default(cuid())
  userId      String
  characterId String
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
  @@index([characterId])
}

/// At most one counted "chat start" per character per dedupeKey (signed-in user or anonymous visitor id).
model CharacterChatStartLedger {
  id          String    @id @default(cuid())
  characterId String
  dedupeKey   String
  createdAt   DateTime  @default(now())
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, dedupeKey])
  @@index([characterId])
}

model Review {
  id          String    @id @default(cuid())
  body        String
  userId      String
  characterId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, characterId])
  @@index([characterId])
}

model PatreonAccount {
  id                    String    @id @default(cuid())
  userId                String    @unique
  patreonUserId         String    @unique
  campaignMemberId      String?
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  tokenExpiresAt        DateTime?
  tierCents             Int?
  membershipStatus      String?
  lastChargeStatus      String?
  lastChargeDate        DateTime?
  nextChargeDate        DateTime?
  lastCheckedAt         DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PatreonOAuthState {
  id            String   @id @default(cuid())
  stateToken    String   @unique
  userId        String
  redirectAfter String?
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Entitlement {
  id         String            @id @default(cuid())
  userId     String
  source     EntitlementSource @default(PATREON)
  tierCode   String
  status     EntitlementStatus @default(INACTIVE)
  validFrom  DateTime?
  validUntil DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model EmailVerificationToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())
  requestedIp String?
  userAgent   String?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, consumedAt])
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())
  requestedIp String?
  userAgent   String?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, consumedAt])
}

model OAuthAccount {
  id             String         @id @default(cuid())
  userId         String
  provider       SocialProvider
  providerUserId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([provider, providerUserId])
  @@index([userId])
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  sessionTokenHash String    @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  lastSeenAt       DateTime?
  ipAddress        String?
  userAgent        String?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([revokedAt])
  @@index([expiresAt, revokedAt])
}

/// User-submitted story adjustments / community posts visible on the public feed.
model StoryPost {
  id                  String                  @id @default(cuid())
  authorId            String
  title               String
  body                String
  characterId         String?
  publicationStatus   StoryPublicationStatus @default(PUBLISHED)
  /// Set when the story is or was published; kept if moved back to draft for ordering/history.
  publishedAt         DateTime?
  likesCount          Int                     @default(0)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  author              User                    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  character           Character?              @relation(fields: [characterId], references: [id], onDelete: SetNull)
  likes               StoryPostLike[]

  @@index([authorId, createdAt])
  @@index([authorId, publicationStatus])
  @@index([publicationStatus, createdAt])
  @@index([characterId])
}

model StoryPostLike {
  id        String    @id @default(cuid())
  userId    String
  storyId   String
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  story     StoryPost @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@index([storyId])
}

enum StoryPublicationStatus {
  DRAFT
  PUBLISHED
}

/// Rolling message quota tracker: one row per user per billing period.
model ChatMessageUsage {
  id             String   @id @default(cuid())
  userId         String
  periodStartAt  DateTime
  periodEndAt    DateTime
  messagesUsed   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodStartAt])
  @@index([userId, periodEndAt])
}

/// Persistent failed-login throttling by client IP to survive process restarts.
model FailedLoginAttempt {
  /// Normalized IP key (Express `request.ip` or remote address fallback).
  ipAddress     String   @id
  attempts      Int      @default(0)
  windowStartAt DateTime
  lockUntil     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([lockUntil])
  @@index([windowStartAt])
}
