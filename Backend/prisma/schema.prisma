generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  CREATOR
  ADMIN
}

enum SocialProvider {
  GOOGLE
  GITHUB
  DISCORD
}

enum CharacterStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

enum CharacterVisibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

enum EntitlementSource {
  PATREON
  STRIPE
  MANUAL
}

enum EntitlementStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

model User {
  id                String           @id @default(cuid())
  email             String           @unique
  username          String           @unique
  passwordHash      String?
  role              UserRole         @default(USER)
  isEmailVerified   Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  characters        Character[]
  hearts            CharacterHeart[]
  reviews           Review[]
  patreonAccount    PatreonAccount?
  patreonOauthState PatreonOAuthState[]
  entitlementGrants Entitlement[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  oauthAccounts           OAuthAccount[]
  sessions                Session[]
}

model Character {
  id               String              @id @default(cuid())
  slug             String              @unique
  name             String
  fullName         String?
  tagline          String?
  description      String?
  personality      String?
  scenario         String?
  firstMessage     String?
  exampleDialogs   String?
  vroidFileUrl     String?
  previewImageUrl  String?
  legacyFileHash   String?
  legacyTier       Int?
  legacyHeyWaifu   Int?
  status           CharacterStatus     @default(DRAFT)
  visibility       CharacterVisibility @default(PRIVATE)
  isPatreonGated   Boolean             @default(false)
  minimumTierCents Int?
  heartsCount      Int                 @default(0)
  averageRating    Float               @default(0)
  viewsCount       Int                 @default(0)
  ownerId          String
  owner            User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  reviews          Review[]
  hearts           CharacterHeart[]
  screenshots      CharacterScreenshot[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  publishedAt      DateTime?

  @@index([ownerId, status])
  @@index([status, visibility])
}

model CharacterHeart {
  id          String    @id @default(cuid())
  userId      String
  characterId String
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
  @@index([characterId])
}

model CharacterScreenshot {
  id          String    @id @default(cuid())
  characterId String
  imageUrl    String
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, sortOrder])
}

model Review {
  id          String    @id @default(cuid())
  rating      Int
  body        String
  userId      String
  characterId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, characterId])
  @@index([characterId])
}

model PatreonAccount {
  id                   String   @id @default(cuid())
  userId               String   @unique
  patreonUserId        String   @unique
  campaignMemberId     String?
  accessTokenEncrypted String?
  refreshTokenEncrypted String?
  tokenExpiresAt       DateTime?
  tierCents            Int?
  membershipStatus     String?
  lastChargeStatus     String?
  lastChargeDate       DateTime?
  nextChargeDate       DateTime?
  lastCheckedAt        DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PatreonOAuthState {
  id            String   @id @default(cuid())
  stateToken    String   @unique
  userId        String
  redirectAfter String?
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Entitlement {
  id         String            @id @default(cuid())
  userId     String
  source     EntitlementSource @default(PATREON)
  tierCode   String
  status     EntitlementStatus @default(INACTIVE)
  validFrom  DateTime?
  validUntil DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model EmailVerificationToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())
  requestedIp String?
  userAgent   String?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, consumedAt])
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())
  requestedIp String?
  userAgent   String?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, consumedAt])
}

model OAuthAccount {
  id             String         @id @default(cuid())
  userId         String
  provider       SocialProvider
  providerUserId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([provider, providerUserId])
  @@index([userId])
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  sessionTokenHash String   @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())
  lastSeenAt       DateTime?
  ipAddress        String?
  userAgent        String?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([revokedAt])
  @@index([expiresAt, revokedAt])
}
