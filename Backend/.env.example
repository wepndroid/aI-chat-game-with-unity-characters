NODE_ENV=development
PORT=4000
DATABASE_URL="file:./prisma/dev.db"
CORS_ORIGIN="http://127.0.0.1:5000,http://localhost:5000"
FRONTEND_URL="http://127.0.0.1:5000"
BACKEND_PUBLIC_URL="http://127.0.0.1:4000"
# Optional: override public base for uploaded VRM/preview URLs (comma-separated for multiple). Defaults to BACKEND_PUBLIC_URL.
# PUBLIC_ASSET_BASE_URL="http://127.0.0.1:4000"
AUTH_COOKIE_NAME="secretwaifu_auth"
AUTH_SESSION_TTL_MS="604800000"
AUTH_EMAIL_VERIFICATION_TOKEN_TTL_MS="86400000"
AUTH_PASSWORD_RESET_TOKEN_TTL_MS="3600000"
AUTH_VERIFY_EMAIL_URL_BASE="http://127.0.0.1:5000/auth/verify-email"
AUTH_RESET_PASSWORD_URL_BASE="http://127.0.0.1:5000/auth/reset-password"
AUTH_OAUTH_STATE_COOKIE_NAME="secretwaifu_oauth_state"
AUTH_OAUTH_STATE_TTL_MS="600000"
AUTH_OAUTH_DEFAULT_REDIRECT_AFTER="/profile"
EMAIL_FROM="SecretWaifu <no-reply@secretwaifu.local>"
EMAIL_SMTP_HOST=""
EMAIL_SMTP_PORT="587"
EMAIL_SMTP_SECURE="false"
EMAIL_SMTP_USER=""
EMAIL_SMTP_PASS=""
GOOGLE_OAUTH_ENABLED="false"
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://127.0.0.1:4000/api/auth/oauth/google/callback"
GOOGLE_OAUTH_SCOPES="openid email profile"
PATREON_OAUTH_ENABLED="false"
PATREON_CLIENT_ID=""
PATREON_CLIENT_SECRET=""
PATREON_REDIRECT_URI="http://127.0.0.1:4000/api/patreon/oauth/callback"
PATREON_SCOPES="identity identity.memberships"
PATREON_CAMPAIGN_ID=""
PATREON_TOKEN_ENCRYPTION_KEY=""
LEGACY_CODE_SECRET=""
LEGACY_VERIFY_CODE_OVERRIDES=""
ADMIN_TEST_BYPASS="false"
# When true (default outside production), session + /auth/me expose every user as ADMIN without changing the database.
# Set to "false" to test real roles locally. In production, defaults to false unless explicitly set to true.
FORCE_ALL_USERS_ADMIN="true"
